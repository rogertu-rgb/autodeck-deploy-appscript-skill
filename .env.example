AUTODECK_GOOGLE_OAUTH=/absolute/path/to/oauth-authorized-user.json
AUTODECK_DATASERVICE_APP_KEY=REPLACE_WITH_DATASERVICE_APP_KEY
AUTODECK_DATASERVICE_APP_SECRET=REPLACE_WITH_DATASERVICE_APP_SECRET
AUTODECK_DATASERVICE_END_USER=REPLACE_WITH_END_USER

# These API values are intentionally kept in the repo because they are service identifiers, not secrets.
AUTODECK_DATASERVICE_API_NAME=cncbbi_general.autodeck__rpt_table_list
AUTODECK_DATASERVICE_API_VERSION=n4rfgou3k5r5mhu7
AUTODECK_DATASERVICE_BASE_URL=https://open-api.datasuite.shopee.io
AUTODECK_DATASERVICE_QUEUE=cncbbi-scheduled
AUTODECK_DATASERVICE_SYSTEM_NAME=autodeck_skill

# Optional local references/fallbacks
AUTODECK_TECH_REFERENCE=/absolute/path/to/local-tech-reference.md
AUTODECK_BRIDGE=/absolute/path/to/datasuite-bridge.sh
